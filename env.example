# ─── Configuration ToutDoux (OPTIONNEL) ───
# Sans ce fichier, les valeurs par défaut s'appliquent (llama3.2, port 3000).
# Pour l'utiliser : copie ce fichier en ".env" et adapte les valeurs,
# puis redémarre le serveur (npm start).

# Modèle Ollama. Liste tes modèles avec : ollama list
OLLAMA_MODEL=llama3.2

# Adresse d'Ollama (à changer seulement en cas de config particulière).
OLLAMA_URL=http://localhost:11434

# Port du serveur web ToutDoux.
PORT=3000
